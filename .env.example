# ─── API Keys ───────────────────────────────────────────────
# Bybit — https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=tu_api_key_aqui
BYBIT_API_SECRET=tu_api_secret_aqui

# Binance — https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# ─── Modo ────────────────────────────────────────────────────
# true = paper trading (sin dinero real), false = real
PAPER_TRADING=true

# ─── Estrategia ──────────────────────────────────────────────
# Rate mínimo (%) para abrir una posición
MIN_FUNDING_RATE=0.02

# Capital en USDT por cada posición
CAPITAL_PER_TRADE=500

# Máximo de posiciones abiertas simultáneas
MAX_POSITIONS=3

# Intervalo entre ciclos en segundos (3600 = 1 hora)
CHECK_INTERVAL=3600
